# ⚠️ 这是示例文件，复制为 .env 后填入你的真实密钥
#    .env 已在 .gitignore 中，不会被提交到 Git

# ========== AI 配置（可选，当前项目已不依赖 AI）==========
# VITE_AI_MODEL=Qwen/QwQ-32B
# VITE_AI_API_URL=https://api.siliconflow.cn/v1/chat/completions
# VITE_AI_KEY=sk-your-siliconflow-key
# VITE_AI_USE_PROXY=true

# ========== Docker 部署 ==========
# GITHUB_TOKEN=github_pat_your_token_here
# PORT=3002

# ========== PartyKit（可选）==========
# VITE_PARTYKIT_HOST=https://your-partykit-host.partykit.dev/

# ========== LinuxDo OAuth（可选）==========
# LINUXDO_CLIENT_ID=your_client_id
# LINUXDO_CLIENT_SECRET=your_client_secret
