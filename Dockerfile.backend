# 后端服务 Dockerfile
FROM node:20-alpine

# 安装编译依赖（sqlite3需要编译）和 wget（用于健康检查）
RUN apk add --no-cache python3 make g++ wget

WORKDIR /app

# 复制后端 package.json
COPY server/package*.json ./server/

# 安装生产依赖
# 使用国内镜像源，增加失败重试，提高构建稳定性
RUN npm config set registry https://registry.npmmirror.com && \
    cd server && \
    npm ci --only=production || \
    npm install --production

# 复制后端源代码
COPY server/ ./server/

# 后端端口
EXPOSE 3002

WORKDIR /app/server

CMD ["npm", "start"]
